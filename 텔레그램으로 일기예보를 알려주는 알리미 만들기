import urllib.request  # 인터넷 주소(URL)에 요청을 보내서 데이터를 받아오는 라이브러리
import json            # JSON 형식 데이터를 파이썬에서 사용할 수 있게 변환하는 라이브러리
import datetime        # 현재 날짜와 시간을 가져오기 위한 라이브러리
import asyncio         # 비동기 방식(동시에 여러 작업 처리)을 위한 라이브러리
from telegram import Bot  # 텔레그램 봇을 사용하기 위한 클래스 가져오기

telegram_id = 'Enter your chat ID here'  # 메시지를 받을 내 텔레그램 chat_id  +++++ 보고서용 이기에 따로 넣어두진않았습니다.
my_token = 'Enter your bot token here'   # BotFather에서 받은 봇 토큰
api_key = 'Enter your API key here'      # OpenWeatherMap에서 받은 API 키

bot = Bot(token=my_token)             # 토큰을 이용해서 텔레그램 봇 객체 생성
ALERT_HOURS = [7, 10, 13, 16, 19, 22] # 정각(00분 00초)에 알림을 보낼 시간 목록 (3시간 간격)
ALERT_TIMES = ["08:30", "14:45"]      # 추가로 원하는 시간에 알림을 보내기 위한 목록

def getWeather():        # 날씨 정보를 가져와서 문자열로 만들어주는 함수
    url = f"https://api.openweathermap.org/data/2.5/forecast?q=Seoul&appid={api_key}&units=metric&lang=en&cnt=8"  
    # 서울의 24시간 날씨 예보 데이터를 요청하는 URL (8개 시간대)
    with urllib.request.urlopen(url) as r:      # 위 URL로 요청을 보내고 응답을 받음
        data = json.loads(r.read())             # 받은 데이터를 JSON → 파이썬 딕셔너리 형태로 변환
        text = ""                               # 결과를 저장할 문자열 변수 초기화
        for i in range(8):                      # 8개의 시간대 데이터를 반복
            item = data['list'][i]              # i번째 날씨 정보 가져오기
            hour = str((int(item['dt_txt'][11:13]) + 9) % 24).zfill(2)  
            # 시간 추출 후 한국시간(KST)으로 변환 (+9시간), 두 자리로 맞춤
            temp = item['main']['temp']  
            # 현재 온도 가져오기
            humi = item['main']['humidity']  
            # 습도 가져오기
            desc = item['weather'][0]['description']  
            # 날씨 상태 설명 가져오기 (예: clear sky)
            text += f"({hour}h {temp}C {humi}% {desc})\n"  
            # 한 줄씩 결과 문자열에 추가
        return text  
            # 완성된 날씨 문자열 반환
async def main():      # 비동기로 실행되는 메인 함수
    try:
        while True:    # 프로그램을 계속 반복 실행
            now = datetime.datetime.now()  
            # 현재 시간 가져오기
            hm = now.strftime('%H:%M')  
            # 현재 시간을 "시:분" 형태로 변환
            is_alert_hour = now.hour in ALERT_HOURS and now.minute == 0 and now.second == 0  
            # 정각 알림 조건 (예: 07:00:00)
            is_alert_time = hm in ALERT_TIMES and now.second == 0  
            # 지정한 시간 알림 조건 (예: 08:30)
            if is_alert_hour or is_alert_time:  
                # 두 조건 중 하나라도 만족하면 실행
                msg = getWeather()  
                # 날씨 정보 가져오기
                print(msg)  
                # 콘솔(터미널)에 출력
                await bot.send_message(chat_id=telegram_id, text=msg)  
                # 텔레그램으로 메시지 전송
            await asyncio.sleep(1) 
                # 1초마다 반복 체크
    except KeyboardInterrupt:  
        # Ctrl + C 누르면 프로그램 종료
        pass
asyncio.run(main())  
# 비동기 메인 함수 실행
