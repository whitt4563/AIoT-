import speech_recognition as sr  # 음성 인식을 위한 speech_recognition 라이브러리를 sr 별칭으로 임포트
import requests                  # 웹 서버에 HTTP 요청을 보내기 위한 requests 라이브러리 임포트
import os                         # 운영체제(OS)와 상호작용(예: 시스템 명령어 실행)하기 위한 os 라이브러리 임포트
import time  # 시간 관련 함수(예: 시간 지연) 사용을 위한 time 라이브러리 임포트

API_KEY = "Enter your API key here"  # OpenWeatherMap API 키 설정. 실제 사용 시 본인의 API 키로 교체 필요

# 서울의 현재 날씨 정보를 요청하는 URL 구성
# 'q=Seoul'은 서울 지역을, 'appid={API_KEY}'는 인증을 위한 API 키를, 'units=metric'은 온도를 섭씨로 받도록 지정
url = f"https://api.openweathermap.org/data/2.5/weather?q=Seoul&appid={API_KEY}&units=metric"

def speak(option, msg):
    """
    주어진 메시지(msg)를 음성으로 출력하는 함수
    espeak 명령어를 사용하여 다양한 음성 옵션(option) 적용 가능
    예시 옵션: '-s 180 -p 50 -a 200 -v ko+f5' (속도 180, 음높이 50, 음량 200, 한국어 여성 음성)
    """
    os.system(f"espeak {option} \'{msg}\'")  # espeak 시스템 명령어를 실행하여 텍스트를 음성으로 변환 및 출력

# 메인 실행 블록: 프로그램 시작 시 이 부분 실행
try:
    while True:  # 프로그램 종료 시까지 무한 반복하여 음성 명령 대기
        r = sr.Recognizer()  # 음성 인식을 담당하는 Recognizer 객체 생성
        with sr.Microphone() as source:  # 시스템의 기본 마이크를 음성 입력 소스로 설정
            print("Say something!")  # 사용자에게 음성 입력을 요청하는 메시지 출력
            # 마이크로부터 음성을 듣고, 이를 오디오 데이터로 저장
            # listen() 메서드는 음성 입력이 끝날 때까지 대기
            audio = r.listen(source)

        try:
            # Google Speech Recognition API를 사용하여 녹음된 오디오를 한국어(ko-KR)로 텍스트 변환
            text = r.recognize_google(audio, language=\'ko-KR\')
            print(f"You said: {text}")  # 인식된 텍스트 출력

            if "날씨" in text:  # 인식된 텍스트에 "날씨" 단어가 포함되어 있는지 확인
                print("날씨 음성 인식 완료.")  # 날씨 관련 음성 명령이 인식되었음을 알림
                response = requests.get(url)  # OpenWeatherMap API에 GET 요청을 보내 날씨 데이터 가져옴
                data = response.json()  # API 응답(JSON 형식)을 파싱하여 Python 딕셔너리 형태로 변환

                temp = data["main"]["temp"]  # 날씨 데이터에서 현재 기온(섭씨) 추출
                humi = data["main"]["humidity"]  # 날씨 데이터에서 현재 습도(%) 추출

                # 사용자에게 안내할 음성 메시지 생성. 기온은 정수형으로 변환하여 표시
                msg = f\'기온은 {int(temp)}도 습도는 {humi}퍼센트입니다.\'
                # espeak 음성 출력 옵션 설정
                # -s: 속도, -p: 음높이, -a: 음량, -v: 음성 언어 및 종류 (ko+f5는 한국어 여성 음성)
                option = \'-s 180 -p 50 -a 200 -v ko+f5\'
                speak(option, msg)  # 설정된 옵션과 함께 날씨 정보를 음성으로 출력

        except sr.UnknownValueError:
            # 음성은 감지되었으나 Google Speech Recognition이 내용을 이해하지 못했을 때 발생하는 예외 처리
            print("Google Speech Recognition could not understand audio")
        except sr.RequestError as e:
            # Google Speech Recognition 서비스로의 요청이 실패했을 때 발생하는 예외 처리
            # 네트워크 문제, API 키 오류 등으로 발생 가능
            print(f"Could not request results from Google Speech Recognition service; {e}")

except KeyboardInterrupt:
    # 사용자가 Ctrl+C를 눌러 프로그램 종료를 요청했을 때 발생하는 예외 처리
    print("프로그램을 종료합니다.")
    pass  # 특별한 종료 처리 없이 루프를 빠져나와 프로그램 종료
