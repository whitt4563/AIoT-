import speech_recognition as sr  # 음성 인식 라이브러리 임포트
import requests                  # HTTP 요청 라이브러리 임포트
import os                        # 시스템 명령어 실행을 위한 os 라이브러리 임포트
import time                      # 시간 지연 처리를 위한 time 라이브러리 임포트

API_KEY = "Enter your API key here"  # OpenWeatherMap API 키 설정

# 서울 날씨 정보 요청 URL (섭씨 단위)
url = f"https://api.openweathermap.org/data/2.5/weather?q=Seoul&appid={API_KEY}&units=metric"

def speak(option, msg):
    os.system(f"espeak {option} \'{msg}\'")  # espeak 명령어로 음성 출력

# 메인 실행 블록
try:
    while True:  # 프로그램 종료 시까지 무한 반복
        r = sr.Recognizer()  # 음성 인식기 객체 생성
        with sr.Microphone() as source:  # 기본 마이크를 입력 소스로 설정
            print("Say something!")  # 음성 입력 안내 메시지
            audio = r.listen(source)  # 마이크 음성 녹음

        try:
            # 녹음된 음성을 한국어로 텍스트 변환
            text = r.recognize_google(audio, language='ko-KR')
            print(f"You said: {text}")  # 인식된 텍스트 출력

            if "날씨" in text:                 # 텍스트에 "날씨" 포함 여부 확인
                print("날씨 음성 인식 완료.")   # 인식 성공 메시지
                response = requests.get(url)   # 날씨 API에 GET 요청
                data = response.json()         # 응답 데이터를 JSON 파싱

                temp = data["main"]["temp"]      # 현재 기온(섭씨) 추출
                humi = data["main"]["humidity"]  # 현재 습도(%) 추출

                # 안내 음성 메시지 생성
                msg = f'기온은 {int(temp)}도 습도는 {humi}퍼센트입니다.'
                # espeak 옵션 설정 (속도, 음높이, 음량, 한국어 여성 음성)
                option = '-s 180 -p 50 -a 200 -v ko+f5'
                speak(option, msg)  # 날씨 정보 음성 출력

        except sr.UnknownValueError:
            # 음성 인식 실패 예외 처리
            print("Google Speech Recognition could not understand audio")
        except sr.RequestError as e:
            # API 요청 실패 예외 처리
            print(f"Could not request results from Google Speech Recognition service; {e}")

except KeyboardInterrupt:  # Ctrl+C 입력 시 프로그램 종료 처리
    print("프로그램을 종료합니다.")
    pass  # 루프 탈출 및 종료
